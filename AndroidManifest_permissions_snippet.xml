<!--
  Add these permission lines to your AndroidManifest.xml, inside the
  <manifest> tag but BEFORE the <application> tag.

  When you run `flutter create .` in the project folder, Flutter generates
  the full manifest. You then merge these two lines in.

  Coarse location is enough for UV index — it only varies over tens of km,
  and requesting only coarse location is friendlier for Play Store review
  and user trust.
-->

<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
<uses-permission android:name="android.permission.INTERNET" />
